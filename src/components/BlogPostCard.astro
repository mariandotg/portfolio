---
import { getLangFromUrl, getLocalizedPath } from "../i18n/utils";

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
}

const { slug, title, description, pubDate } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const formattedDate = pubDate.toLocaleDateString(lang === "es" ? "es-AR" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const href = getLocalizedPath(`/blog/${slug}`, lang);
---

<a href={href} class="block py-4 group">
  <time
    datetime={pubDate.toISOString()}
    class="block text-xs mb-1"
    style="font-family: var(--font-family-mono); color: var(--color-muted);"
  >{formattedDate}</time>

  <h3 class="text-[15px] font-semibold leading-snug mb-1 text-[var(--color-fg)] dark:text-[var(--color-fg-dark)]" style="transition: color 150ms ease-in-out;">
    {title}
  </h3>

  <p class="text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] line-clamp-1">
    {description}
  </p>
</a>

<style>
  a:hover h3 {
    color: var(--color-primary);
  }

  html.dark a:hover h3 {
    color: var(--color-primary-hover);
  }
</style>
