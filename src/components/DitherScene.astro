<!-- Dither scene wrapper: absolute hero layer behind text. -->
<div class="dither-wrapper">
  <canvas id="dither-canvas" aria-hidden="true"></canvas>
</div>

<style>
  .dither-wrapper {
    position: absolute;
    inset: -14% -14% -18% -8%;
    z-index: 2;
    pointer-events: none;
    overflow: visible;
    opacity: 0;
    transition: opacity 0.65s ease;
    /* transform: translateX(21%) translateY(-2%); */
  }

  .dither-wrapper.visible {
    opacity: 1;
  }

  #dither-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 900px) {
    .dither-wrapper {
      inset: -10% -20% -16% -18%;
      transform: translateX(10%) translateY(-1%);
    }
  }

  @media (max-width: 640px) {
    .dither-wrapper {
      inset: -4% -20% -16% -24%;
      transform: translateX(4%) translateY(8%);
      opacity: 0.9;
    }
  }
</style>

<script>
  import { init } from "./dither-scene/renderer";

  const canvas = document.getElementById("dither-canvas") as HTMLCanvasElement;
  if (canvas) {
    const cleanup = init(canvas);
    // Fade in after first paint
    requestAnimationFrame(() => {
      canvas.parentElement?.classList.add("visible");
    });
  }
</script>
