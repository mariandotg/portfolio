---
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const enPath = currentPath.replace(/^\/es/, "") || "/";
const esPath = `/es${enPath === "/" ? "" : enPath}` || "/es";
---

<div class="flex items-center gap-1 text-sm font-medium">
  <a
    href={enPath}
    class:list={[
      "px-2 py-1 rounded transition-colors",
      lang === "en"
        ? "text-[var(--color-primary)] font-bold"
        : "text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] hover:text-[var(--color-primary)]"
    ]}
    aria-label="Switch to English"
  >EN</a>
  <span class="text-[var(--color-light-subtle)] dark:text-[var(--color-dark-subtle)]">/</span>
  <a
    href={esPath}
    class:list={[
      "px-2 py-1 rounded transition-colors",
      lang === "es"
        ? "text-[var(--color-primary)] font-bold"
        : "text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] hover:text-[var(--color-primary)]"
    ]}
    aria-label="Cambiar a Español"
  >ES</a>
</div>
