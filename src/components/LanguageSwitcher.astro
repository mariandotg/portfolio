---
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

const enPath = currentPath.replace(/^\/es/, "") || "/";
const esPath = `/es${enPath === "/" ? "" : enPath}` || "/es";
---

<div class="flex items-center gap-0.5 text-xs">
  <a
    href={enPath}
    class:list={[
      "px-1",
      lang === "en"
        ? "font-semibold text-[var(--color-fg)] dark:text-[var(--color-fg-dark)]"
        : "text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] hover:text-[var(--color-fg)] dark:hover:text-[var(--color-fg-dark)]"
    ]}
    style="transition: color 150ms ease-in-out;"
    aria-label="Switch to English"
  >EN</a>
  <span class="text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">/</span>
  <a
    href={esPath}
    class:list={[
      "px-1",
      lang === "es"
        ? "font-semibold text-[var(--color-fg)] dark:text-[var(--color-fg-dark)]"
        : "text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] hover:text-[var(--color-fg)] dark:hover:text-[var(--color-fg-dark)]"
    ]}
    style="transition: color 150ms ease-in-out;"
    aria-label="Cambiar a Español"
  >ES</a>
</div>
