---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.tsx";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { SITE } from "../config";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="sticky top-0 z-50 w-full border-b bg-[var(--color-bg)]/95 dark:bg-[var(--color-bg-dark)]/95" style="border-color: var(--color-border);">
  <nav class="max-w-[800px] mx-auto px-4 sm:px-6 lg:px-12 h-14 flex items-center justify-between">
    <!-- Site name -->
    <a href={getLocalizedPath("/blog", lang)} class="text-sm font-semibold text-[var(--color-fg)] dark:text-[var(--color-fg-dark)] hover:opacity-70" style="transition: opacity 150ms ease-in-out;">
      {SITE.name}
    </a>

    <!-- Right side -->
    <div class="flex items-center gap-4">
      <a
        href={getLocalizedPath("/blog", lang)}
        class="text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] hover:text-[var(--color-fg)] dark:hover:text-[var(--color-fg-dark)]"
        style="transition: color 150ms ease-in-out;"
      >
        {t.nav.blog}
      </a>
      <LanguageSwitcher />
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
