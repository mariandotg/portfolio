---
interface Props {
  tags: string[];
  class?: string;
}
const { tags, class: className } = Astro.props;
---

<div class:list={["flex flex-wrap gap-3", className]}>
  {tags.map((tag) => (
    <span style="font-family: var(--font-family-mono); font-size: 12px; color: var(--color-muted);">
      #{tag}
    </span>
  ))}
</div>
