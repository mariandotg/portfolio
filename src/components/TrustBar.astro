---
const signals = [
  "On-time delivery",
  "Weekly updates",
  "Transparent pricing",
  "Ongoing support",
];
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-2">
  {
    signals.map((signal, i) => (
      <span class="text-sm font-mono text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] opacity-50">
        {signal}{i < signals.length - 1 ? " ·" : ""}
      </span>
    ))
  }
</div>
