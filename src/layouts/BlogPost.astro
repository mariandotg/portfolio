---
import PageLayout from "./PageLayout.astro";
import TagList from "../components/TagList.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  readingTime?: number;
}

const { title, description, pubDate, updatedDate, tags = [], image, imageAlt, readingTime } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const formattedDate = pubDate.toLocaleDateString(lang === "es" ? "es-AR" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdated = updatedDate?.toLocaleDateString(lang === "es" ? "es-AR" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<PageLayout title={title} description={description} image={image} type="article" pubDate={pubDate}>
  <article class="max-w-[800px] mx-auto px-4 sm:px-6 lg:px-12 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-3" style="font-family: var(--font-family-mono); font-size: 12px; color: var(--color-muted);">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span>·</span>
            <span>{readingTime} {t.blog.readingTime}</span>
          </>
        )}
        {formattedUpdated && (
          <>
            <span>·</span>
            <span>Updated {formattedUpdated}</span>
          </>
        )}
      </div>

      <h1 class="text-xl font-semibold leading-snug mb-3 text-[var(--color-fg)] dark:text-[var(--color-fg-dark)]">
        {title}
      </h1>

      <p class="text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)] mb-4">
        {description}
      </p>

      {tags.length > 0 && <TagList tags={tags} />}
    </header>

    <hr class="mb-8" style="border-color: var(--color-border); opacity: 0.5;" />

    {image && (
      <img
        src={image}
        alt={imageAlt || title}
        class="w-full mb-8"
        style="border-radius: 4px;"
      />
    )}

    <div class="prose prose-sm dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>
</PageLayout>
