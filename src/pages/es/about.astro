---
import PageLayout from "../../layouts/PageLayout.astro";
import CTABanner from "../../components/CTABanner.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experience = [
  { role: "Tech Lead", company: "Stefanini Group", period: "2024 – Presente", desc: "Liderando equipos de desarrollo para clientes enterprise como Renault y Banco Macro. Decisiones de arquitectura, code reviews, mentoría y desarrollo hands-on cuando las cosas se ponen complejas.", tags: ["React", "Node.js", "TypeScript", "Liderazgo", "Arquitectura"] },
  { role: "Fullstack Developer", company: "Stefanini Group", period: "2023 – 2024", desc: "Construí y entregué productos para clientes como Interbanking. Trabajo enfocado en backend incluyendo migración de monolito a microservicios para plataformas financieras.", tags: ["Node.js", "Microservicios", "TypeScript", "React"] },
  { role: "Fullstack Developer", company: "Freelance / Consultoría", period: "2021 – 2023", desc: "Trabajo freelance y de consultoría construyendo aplicaciones web y librerías de componentes para varios clientes.", tags: ["React", "Next.js", "TypeScript", "Tailwind CSS"] },
];

const skills = {
  "Frontend": ["React", "Next.js", "Astro", "TypeScript", "Tailwind CSS", "HTML/CSS"],
  "Backend": ["Node.js", "Express", "PostgreSQL", "Prisma", "REST APIs", "GraphQL"],
  "DevOps": ["Vercel", "Docker", "GitHub Actions", "AWS"],
  "Herramientas": ["Git", "Figma", "VS Code", "Storybook"],
};
---

<PageLayout title={t.about.pageTitle} description={t.about.pageSubtitle}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <SectionHeader title={t.about.pageTitle} subtitle={t.about.pageSubtitle} />
    <div class="grid md:grid-cols-3 gap-10 mb-20">
      <div class="md:col-span-2">
        <h2 class="text-2xl font-bold text-[var(--color-light-headlines)] dark:text-[var(--color-dark-headlines)] mb-4">{t.about.bioTitle}</h2>
        {t.about.bio.split("\n\n").map((para) => (
          <p class="text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] mb-4 leading-relaxed">{para}</p>
        ))}
      </div>
      <div class="flex justify-center md:justify-start">
        <div class="w-48 h-48 rounded-full bg-[color-mix(in_srgb,var(--color-primary)_15%,transparent)] flex items-center justify-center text-6xl">👨‍💻</div>
      </div>
    </div>
    <div class="mb-20">
      <SectionHeader title={t.about.experienceTitle} />
      <div class="space-y-6">
        {experience.map(({ role, company, period, desc, tags }) => (
          <div class="p-6 rounded-[var(--radius-md)] border border-[var(--color-light-subtle)] dark:border-[var(--color-dark-subtle)]">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
              <div>
                <h3 class="font-bold text-[var(--color-light-headlines)] dark:text-[var(--color-dark-headlines)]">{role}</h3>
                <p class="text-[var(--color-primary)] text-sm font-medium">{company}</p>
              </div>
              <span class="text-sm text-[var(--color-light-text)] dark:text-[var(--color-dark-text)]">{period}</span>
            </div>
            <p class="text-sm text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] mb-3">{desc}</p>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="px-2 py-0.5 text-xs rounded-full bg-[var(--color-light-subtle)] dark:bg-[var(--color-dark-subtle)] text-[var(--color-light-text)] dark:text-[var(--color-dark-text)]">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="mb-20">
      <SectionHeader title={t.about.skillsTitle} />
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="font-bold text-[var(--color-light-headlines)] dark:text-[var(--color-dark-headlines)] mb-3">{category}</h3>
            <ul class="space-y-2">
              {items.map((item) => (
                <li class="text-sm text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <CTABanner title={t.home.ctaBannerTitle} subtitle={t.home.ctaBannerSub} btnLabel={t.about.ctaBtn} btnHref={getLocalizedPath("/contact", lang)} />
  </div>
</PageLayout>
