---
import PageLayout from "../layouts/PageLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BlogPostCard from "../components/BlogPostCard.astro";
import CTABanner from "../components/CTABanner.astro";
import Button from "../components/Button.astro";
import SocialLinks from "../components/SocialLinks.astro";
import TrustBar from "../components/TrustBar.astro";
import DitherScene from "../components/DitherScene.astro";
import { SITE } from "../config";
import { getCollection } from "astro:content";
import { useTranslations, getLangFromUrl, getLocalizedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isBookingExternal = SITE.bookingUrl.startsWith("http");

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const painPoints = [
  { icon: "🕐", title: t.home.pain1Title, desc: t.home.pain1Desc },
  { icon: "🏗️", title: t.home.pain2Title, desc: t.home.pain2Desc },
  { icon: "🤝", title: t.home.pain3Title, desc: t.home.pain3Desc },
];

const services = [
  {
    icon: "⚡",
    title: t.home.service1Title,
    desc: t.home.service1Desc,
    href: getLocalizedPath("/services", lang) + "#fullstack",
  },
  {
    icon: "🔍",
    title: t.home.service2Title,
    desc: t.home.service2Desc,
    href: getLocalizedPath("/services", lang) + "#consulting",
  },
  {
    icon: "🔄",
    title: t.home.service3Title,
    desc: t.home.service3Desc,
    href: getLocalizedPath("/services", lang) + "#modernization",
  },
];

const clientLogos = ["Renault", "Interbanking", "Banco Macro"];

const steps = [
  { n: "01", title: t.services.step1, desc: t.services.step1Desc },
  { n: "02", title: t.services.step2, desc: t.services.step2Desc },
  { n: "03", title: t.services.step3, desc: t.services.step3Desc },
  { n: "04", title: t.services.step4, desc: t.services.step4Desc },
];

const stats = [
  { value: t.home.stat1Value, label: t.home.stat1Label },
  { value: t.home.stat2Value, label: t.home.stat2Label },
  { value: t.home.stat3Value, label: t.home.stat3Label },
  { value: t.home.stat4Value, label: t.home.stat4Label },
];

const outcomes = [
  { value: t.home.proof1Value, label: t.home.proof1Label },
  { value: t.home.proof2Value, label: t.home.proof2Label },
  { value: t.home.proof3Value, label: t.home.proof3Label },
];

const engagementPaths = [
  {
    title: t.home.lane1Title,
    desc: t.home.lane1Desc,
    cta: t.home.lane1Cta,
    href: SITE.bookingUrl,
    external: isBookingExternal,
  },
  {
    title: t.home.lane2Title,
    desc: t.home.lane2Desc,
    cta: t.home.lane2Cta,
    href: getLocalizedPath("/contact", lang),
    external: false,
  },
];

---

<PageLayout>
  <!-- Hero -->
  <div class="hero-dither-blobs" aria-hidden="true">
    <span class="hero-dither-blob hero-dither-blob-1"></span>
    <span class="hero-dither-blob hero-dither-blob-2"></span>
  </div>
  <section class="hero-shell relative overflow-hidden flex justify-center px-4 pb-16 mx-auto max-w-5xl min-h-[calc(100vh-80px)] sm:px-6">
    <div class="hero-noise" aria-hidden="true"></div>
    <DitherScene />
    <div class="hero-bridge" aria-hidden="true"></div>
    <div class="hero-text-fade" aria-hidden="true"></div>
    <div class="hero-content relative z-10 flex flex-col justify-center w-full" data-parallax-root>
      <div class="hero-eyebrow mb-5 hero-parallax" data-parallax-depth="0.1">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 text-xs font-medium rounded-full bg-[color-mix(in_srgb,var(--color-primary)_10%,transparent)] text-[var(--color-primary)] border border-[color-mix(in_srgb,var(--color-primary)_25%,transparent)]">
          <span class="size-1.5 rounded-full bg-[var(--color-primary)] inline-block"></span>
          {t.home.available}
        </span>
      </div>
      <h1 class="hero-title hero-parallax text-4xl sm:text-5xl lg:text-6xl font-extralight text-[var(--color-light-headlines)] dark:text-[var(--color-dark-headlines)] leading-[1.15] mb-6" data-parallax-depth="0.2">
        {t.home.heroTitle}<br /><span class="hero-title-accent font-medium" data-accent={t.home.heroTitleAccent}>{t.home.heroTitleAccent}</span>.
      </h1>
      <p class="hero-sub hero-parallax mb-8 max-w-xl text-lg sm:text-xl text-[var(--color-light-text)] dark:text-[#f3f3f3] font-inter" data-parallax-depth="0.14">
        {t.home.heroSub}
      </p>
      <div class="hero-cta hero-parallax flex flex-wrap gap-4 mb-10" data-parallax-depth="0.12">
        <div class="hero-cta-primary">
          <Button
            href={SITE.bookingUrl}
            target={isBookingExternal ? "_blank" : undefined}
            rel={isBookingExternal ? "noopener noreferrer" : undefined}
            class="hero-cta-main-btn"
          >
            {t.home.heroCta}
          </Button>
        </div>
        <div>
          <Button href="#process" variant="secondary" class="hero-cta-secondary-btn">{t.home.heroSecondary}</Button>
        </div>
      </div>
      <div class="hero-proof hero-parallax grid gap-3 sm:grid-cols-3 mb-10 max-w-3xl" data-parallax-depth="0.08">
        {
          outcomes.map(({ value, label }, idx) => (
            <div class="hero-proof-card rounded-[var(--radius-sm)] border border-[var(--color-light-subtle)] dark:border-[var(--color-dark-subtle)] px-4 py-3" style={`--proof-delay:${idx * 2.4}s;`}>
              <p class="hero-proof-value text-2xl sm:text-[1.7rem] font-semibold text-[var(--color-light-headlines)] dark:text-[var(--color-dark-headlines)]" data-proof-number data-proof-value={value}>{value}</p>
              <p class="hero-proof-label text-xs text-[var(--color-light-text)] dark:text-[var(--color-dark-text)]">{label}</p>
            </div>
          ))
        }
      </div>
      <div class="hero-social hero-parallax mb-6" data-parallax-depth="0.06">
        <SocialLinks />
      </div>
      <div class="hero-trust hero-parallax" data-parallax-depth="0.04">
        <TrustBar />
      </div>
    </div>
  </section>

  <!-- Client Logos -->
  <!-- <section data-scroll class="max-w-5xl mx-auto px-4 sm:px-6 py-12 border-t border-[var(--color-light-subtle)] dark:border-[var(--color-dark-subtle)]">
    <p class="text-center text-sm text-[var(--color-light-text)] dark:text-[var(--color-dark-text)] mb-6">{t.home.clientsTitle}</p>
    <div class="flex flex-wrap justify-center items-center gap-8 sm:gap-12">
      {clientLogos.map((name) => (
        <span class="text-lg sm:text-xl font-bold text-[var(--color-light-headlines)] dark:text-[var(--color-dark-headlines)] opacity-50 hover:opacity-80 transition-opacity">{name}</span>
      ))}
    </div>
  </section> -->

  <!-- Engagement Paths -->
  <!-- <section data-scroll class="max-w-5xl mx-auto px-4 sm:px-6 py-16 border-t border-[var(--color-light-subtle)] dark:border-[var(--color-dark-subtle)]">
